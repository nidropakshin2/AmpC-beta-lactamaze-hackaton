{
    "run_type": "staged_learning",
    "device": "cpu",
    "use_cuda": true,
    "tb_logdir": "reinvent/logs/tb",
    "json_out_config": "reinvent/configs/config.json",
    "seed": null,
    "parameters": {
        "prior_file": "c:\\Users\\Mikhail\\miniconda3\\envs\\sber_hack\\Lib\\site-packages\\reinvent\\..\\priors\\reinvent.prior",
        "agent_file": "c:\\Users\\Mikhail\\miniconda3\\envs\\sber_hack\\Lib\\site-packages\\reinvent\\..\\priors\\reinvent.prior",
        "summary_csv_prefix": "reinvent/data/agent",
        "use_checkpoint": true,
        "purge_memories": true,
        "smiles_file": null,
        "sample_strategy": "multinomial",
        "distance_threshold": 99999,
        "batch_size": 100,
        "randomize_smiles": true,
        "unique_sequences": false,
        "temperature": 1.0,
        "tb_isim": false
    },
    "scoring": null,
    "scheduler": null,
    "responder": null,
    "filter": null,
    "stage": [
        {
            "max_steps": 200,
            "max_score": 1.0,
            "chkpt_file": "reinvent/checkpoints/agent.chkpt",
            "termination": "simple",
            "min_steps": 50,
            "scoring": {
                "type": "geometric_mean",
                "component": [
                    {
                        "QED": {
                            "endpoint": [
                                {
                                    "name": "qed",
                                    "weight": 0.3,
                                    "transform": {
                                        "type": "sigmoid",
                                        "low": 0.6,
                                        "high": 0.9,
                                        "k": 0.5
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "SAScore": {
                            "endpoint": [
                                {
                                    "name": "SA_score",
                                    "weight": 0.3,
                                    "transform": {
                                        "type": "reverse_sigmoid",
                                        "low": 1.0,
                                        "high": 4.0,
                                        "k": 0.5
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "TanimotoDistance": {
                            "endpoint": [
                                {
                                    "name": "tanimoto_dissimilarity",
                                    "weight": 0.3,
                                    "params": {
                                        "smiles": [
                                            "COc1cccc(Nc2c(C(N)=O)cnc3c(C)cc(S(=O)(=O)c4cccc(C(=O)N(C)C)c4)cc23)c1",
                                            "COc1ccc(-c2nc(C(=O)NCc3coc4ccccc34)c([C@@H](C)N)o2)c2ccc(C(F)(F)F)nc12",
                                            "COc1cccc(Nc2c(C(N)=O)cnc3ccc(S(=O)(=O)c4cccc(C(=O)N(C)C)c4)cc23)c1",
                                            "Cc1cc(C(=O)N[C@H]2CC[C@@H](NC(=O)c3cc(F)cnc3Oc3cccc(-c4ccc(O)cc4CN4CCCOCC4)c3)CC2)nn1C",
                                            "Cn1nc(C(=O)NC2CCC(NC(=O)c3cc(F)cnc3Oc3cccc(-c4ccc(CCCN5CCNCC5)cc4)c3)CC2)cc1C(F)(F)F"
                                        ],
                                        "radius": 2,
                                        "use_counts": true,
                                        "use_features": false
                                    },
                                    "transform": {
                                        "type": "reverse_sigmoid",
                                        "low": 0.2,
                                        "high": 0.5,
                                        "k": 0.5
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "custom_alerts": {
                            "endpoint": [
                                {
                                    "name": "brenk_filter",
                                    "weight": 0.7,
                                    "params": {
                                        "smarts": [
                                            "[#6;r3]1~[#6;r3]~[#6;r3]1",
                                            "[#6](=O)[F,Cl,Br,I]",
                                            "[CH1](=O)",
                                            "[S;X2](=O)",
                                            "[C,c]-S(=O)(=O)-[Cl]",
                                            "[$(N-!@[O;!$(O=*)])]",
                                            "N=!@N",
                                            "[N;!$(N-C=O)]~[N;!$(N-C=O)]",
                                            "C(=O)OC(=O)",
                                            "C=CC(=O)",
                                            "O=CN=[N+]=[N-]",
                                            "[#7;!$(N-C=O);!$(N-S=O)]-[Cl,Br,I]",
                                            "c1ccc2c(c1)ccc3cccc4cccc2c34",
                                            "c1ccc2[nH]ccc2c1",
                                            "[OH]c1ccc(cc1)[NH2]",
                                            "c1ccc(cc1)N",
                                            "[N+](=O)[O-]",
                                            "C(=O)N(C=O)",
                                            "[SH]",
                                            "c1ccc(cc1)C=NNc2ccccc2",
                                            "O=C1C=CC(=O)c2ccccc21",
                                            "C1=CC(=O)C=CC1=O",
                                            "c1ccc(cc1)-c2ccc(cc2)O",
                                            "Oc1ccc(cc1)-c2cccc(c2)O",
                                            "[#6]~[#7]~[#7]~[#6]",
                                            "[#6;r8,r9,r10,r11,r12,r13,r14]",
                                            "[F,Cl,Br,I]-[F,Cl,Br,I]",
                                            "[$(C#N),$(N#C)]",
                                            "C(=O)Cl",
                                            "[P;!$(P(=O))]",
                                            "[Se]",
                                            "[Te]"
                                        ]
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "Qptuna": {
                            "endpoint": [
                                {
                                    "name": "Qptuna",
                                    "weight": 2,
                                    "params": {
                                        "model_file": "qsar/model/latest.pkl"
                                    },
                                    "transform": {
                                        "type": "sigmoid",
                                        "high": 9,
                                        "low": 3,
                                        "k": 1
                                    }
                                }
                            ]
                        }
                    }
                ],
                "filename": null
            },
            "diversity_filter": null
        }
    ],
    "learning_strategy": {
        "type": "dap",
        "sigma": 80,
        "rate": 0.0003
    },
    "diversity_filter": {
        "type": "IdenticalMurckoScaffold",
        "bucket_size": 25,
        "minscore": 0.4,
        "minsimilarity": 0.4,
        "penalty_multiplier": 0.5
    },
    "intrinsic_penalty": null,
    "inception": null
}